# PostgreSQL
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://activist:changeme_in_production@localhost:5432/activist_terminal

# Python pipeline uses psycopg2 driver
PIPELINE_DATABASE_URL=postgresql+psycopg2://activist:changeme_in_production@localhost:5432/activist_terminal

# Next.js / NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# FastAPI (internal analytics service)
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# SEC EDGAR
SEC_USER_AGENT=YourName yourname@example.com
SEC_RATE_LIMIT_RPS=10

# Price data (yfinance / polygon)
POLYGON_API_KEY=

# Logging
LOG_LEVEL=INFO
